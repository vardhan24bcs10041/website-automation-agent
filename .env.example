# Google Gemini API key (required). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ordered model fallback chain (comma-separated). The agent starts on the first
# model and automatically switches to the next when one is rate-limited (429) or
# unavailable (404). All models must support vision + function calling.
# Leave unset to use the built-in default chain.
# GEMINI_MODELS=gemini-2.5-flash,gemini-3.5-flash,gemini-3-flash-preview,gemini-2.5-flash-lite,gemini-3.1-flash-lite

# The web page the agent should start on
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form

# Run the browser without a visible window (true/false)
HEADLESS=false

# Maximum number of vision->decision->action steps before the agent stops
MAX_STEPS=25

# Browser viewport size in pixels (also the screenshot/coordinate space)
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800
